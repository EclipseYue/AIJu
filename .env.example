APP_ENV=development

# OpenAI-compatible LLM provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Anthropic-compatible LLM provider. Keep actual tokens only in .env.
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=
ANTHROPIC_SMALL_FAST_MODEL=

# Local embedding model. Recommended for Chinese textbooks.
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# External textbook data path; keep PDFs outside this Git repository.
TEXTBOOK_DATA_DIR=../textbooks

# Local runtime directories, ignored by git.
UPLOAD_DIR=data/uploads
CHROMA_DIR=data/chroma
DATABASE_PATH=data/aiju.sqlite

# Frontend
VITE_API_BASE=http://localhost:8000
